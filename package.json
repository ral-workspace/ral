{
  "private": true,
  "name": "ral",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --filter @ral/desktop tauri dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "test": "turbo test",
    "release": "./scripts/release.sh",
    "test:e2e": "pnpm --filter @ral/desktop test:e2e",
    "test:e2e:full": "pnpm --filter @ral/desktop test:e2e:full"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.4.2",
      "serialize-javascript": ">=7.0.3",
      "dompurify": ">=3.3.2",
      "hono": ">=4.12.7"
    }
  }
}
