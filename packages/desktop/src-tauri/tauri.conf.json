{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ral",
  "version": "0.2.5",
  "identifier": "com.shumpeiokanoue.ral",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "visible": false,
        "titleBarStyle": "Overlay",
        "decorations": true,
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "backgroundColor": [
          24,
          24,
          27,
          255
        ]
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$HOME/.ral/**"
        ]
      }
    }
  },
  "plugins": {
    "cli": {
      "description": "Ral - AI workspace",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/icon-themes/": "icon-themes/",
      "resources/sandbox-proxy.html": "sandbox-proxy.html",
      "resources/python/": "python/",
      "resources/node/": "node/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "files": {
        "Resources/Assets.car": "resources/Assets.car"
      }
    }
  }
}
